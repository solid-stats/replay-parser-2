{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ParseResultMessage",
  "description": "Parser-worker result message envelope.",
  "anyOf": [
    {
      "description": "Successful parser-worker result.",
      "$ref": "#/$defs/ParseCompletedMessage"
    },
    {
      "description": "Failed parser-worker result.",
      "$ref": "#/$defs/ParseFailedMessage"
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "ArtifactReference": {
      "description": "S3-compatible object reference for a parser artifact.",
      "type": "object",
      "properties": {
        "bucket": {
          "description": "Artifact object bucket.",
          "type": "string"
        },
        "key": {
          "description": "Artifact object key.",
          "type": "string"
        }
      },
      "required": [
        "bucket",
        "key"
      ]
    },
    "ChecksumAlgorithm": {
      "description": "Supported source checksum algorithms.",
      "oneOf": [
        {
          "description": "SHA-256 checksum.",
          "type": "string",
          "const": "sha256"
        }
      ]
    },
    "ChecksumValue": {
      "description": "Lowercase hexadecimal SHA-256 checksum value.",
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "Confidence": {
      "description": "Confidence score for inferred field values.",
      "type": "number",
      "format": "float",
      "maximum": 1.0,
      "minimum": 0.0
    },
    "ContractVersion": {
      "description": "Semantic parser artifact contract version.",
      "$ref": "#/$defs/SemVer"
    },
    "ErrorCode": {
      "description": "Stable namespaced parse failure code.",
      "type": "string",
      "pattern": "^(io|json|schema|unsupported|internal|checksum|output)\\.[a-z0-9_-]+(\\.[a-z0-9_-]+)*$"
    },
    "FieldPresence": {
      "description": "Explicit state wrapper for fields that may be present, null, unknown, inferred, or irrelevant.",
      "oneOf": [
        {
          "description": "Field was present in the source or adapter input.",
          "type": "object",
          "properties": {
            "source": {
              "description": "Source reference for the value, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "present"
            },
            "value": {
              "description": "Present value.",
              "type": "string"
            }
          },
          "required": [
            "state",
            "value"
          ]
        },
        {
          "description": "Field was explicitly null in the source or domain event.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is null.",
              "$ref": "#/$defs/NullReason"
            },
            "source": {
              "description": "Source reference for the null state, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "explicit_null"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "description": "Field value is unknown.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is unknown.",
              "$ref": "#/$defs/UnknownReason"
            },
            "source": {
              "description": "Source reference for the unknown state, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "unknown"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "description": "Field value was inferred rather than directly observed.",
          "type": "object",
          "properties": {
            "confidence": {
              "description": "Optional confidence score for the inference.",
              "anyOf": [
                {
                  "$ref": "#/$defs/Confidence"
                },
                {
                  "type": "null"
                }
              ]
            },
            "reason": {
              "description": "Human-readable inference reason.",
              "type": "string"
            },
            "rule_id": {
              "description": "Rule that produced the inference.",
              "$ref": "#/$defs/RuleId"
            },
            "source": {
              "description": "Source reference for the inference, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "inferred"
            },
            "value": {
              "description": "Inferred value.",
              "type": "string"
            }
          },
          "required": [
            "state",
            "value",
            "reason",
            "rule_id"
          ]
        },
        {
          "description": "Field does not apply to this replay, entity, event, or projection.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is not applicable.",
              "type": "string"
            },
            "state": {
              "type": "string",
              "const": "not_applicable"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        }
      ]
    },
    "FieldPresence2": {
      "description": "Explicit state wrapper for fields that may be present, null, unknown, inferred, or irrelevant.",
      "oneOf": [
        {
          "description": "Field was present in the source or adapter input.",
          "type": "object",
          "properties": {
            "source": {
              "description": "Source reference for the value, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "present"
            },
            "value": {
              "description": "Present value.",
              "$ref": "#/$defs/ContractVersion"
            }
          },
          "required": [
            "state",
            "value"
          ]
        },
        {
          "description": "Field was explicitly null in the source or domain event.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is null.",
              "$ref": "#/$defs/NullReason"
            },
            "source": {
              "description": "Source reference for the null state, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "explicit_null"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "description": "Field value is unknown.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is unknown.",
              "$ref": "#/$defs/UnknownReason"
            },
            "source": {
              "description": "Source reference for the unknown state, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "unknown"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "description": "Field value was inferred rather than directly observed.",
          "type": "object",
          "properties": {
            "confidence": {
              "description": "Optional confidence score for the inference.",
              "anyOf": [
                {
                  "$ref": "#/$defs/Confidence"
                },
                {
                  "type": "null"
                }
              ]
            },
            "reason": {
              "description": "Human-readable inference reason.",
              "type": "string"
            },
            "rule_id": {
              "description": "Rule that produced the inference.",
              "$ref": "#/$defs/RuleId"
            },
            "source": {
              "description": "Source reference for the inference, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "inferred"
            },
            "value": {
              "description": "Inferred value.",
              "$ref": "#/$defs/ContractVersion"
            }
          },
          "required": [
            "state",
            "value",
            "reason",
            "rule_id"
          ]
        },
        {
          "description": "Field does not apply to this replay, entity, event, or projection.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is not applicable.",
              "type": "string"
            },
            "state": {
              "type": "string",
              "const": "not_applicable"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        }
      ]
    },
    "FieldPresence3": {
      "description": "Explicit state wrapper for fields that may be present, null, unknown, inferred, or irrelevant.",
      "oneOf": [
        {
          "description": "Field was present in the source or adapter input.",
          "type": "object",
          "properties": {
            "source": {
              "description": "Source reference for the value, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "present"
            },
            "value": {
              "description": "Present value.",
              "$ref": "#/$defs/SourceChecksum"
            }
          },
          "required": [
            "state",
            "value"
          ]
        },
        {
          "description": "Field was explicitly null in the source or domain event.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is null.",
              "$ref": "#/$defs/NullReason"
            },
            "source": {
              "description": "Source reference for the null state, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "explicit_null"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "description": "Field value is unknown.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is unknown.",
              "$ref": "#/$defs/UnknownReason"
            },
            "source": {
              "description": "Source reference for the unknown state, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "unknown"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "description": "Field value was inferred rather than directly observed.",
          "type": "object",
          "properties": {
            "confidence": {
              "description": "Optional confidence score for the inference.",
              "anyOf": [
                {
                  "$ref": "#/$defs/Confidence"
                },
                {
                  "type": "null"
                }
              ]
            },
            "reason": {
              "description": "Human-readable inference reason.",
              "type": "string"
            },
            "rule_id": {
              "description": "Rule that produced the inference.",
              "$ref": "#/$defs/RuleId"
            },
            "source": {
              "description": "Source reference for the inference, when available.",
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "inferred"
            },
            "value": {
              "description": "Inferred value.",
              "$ref": "#/$defs/SourceChecksum"
            }
          },
          "required": [
            "state",
            "value",
            "reason",
            "rule_id"
          ]
        },
        {
          "description": "Field does not apply to this replay, entity, event, or projection.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "Reason the field is not applicable.",
              "type": "string"
            },
            "state": {
              "type": "string",
              "const": "not_applicable"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        }
      ]
    },
    "NullReason": {
      "description": "Reason for an explicit null field state.",
      "oneOf": [
        {
          "description": "Killer is explicitly null.",
          "type": "string",
          "const": "null_killer"
        },
        {
          "description": "Source field value was null.",
          "type": "string",
          "const": "source_null"
        },
        {
          "description": "Source field was empty and normalized to null.",
          "type": "string",
          "const": "empty_value"
        }
      ]
    },
    "ParseCompletedMessage": {
      "description": "Successful parser-worker result message.",
      "type": "object",
      "properties": {
        "artifact": {
          "description": "Durable parser artifact object reference.",
          "$ref": "#/$defs/ArtifactReference"
        },
        "artifact_checksum": {
          "description": "SHA-256 checksum of the exact artifact bytes written to storage.",
          "$ref": "#/$defs/SourceChecksum"
        },
        "artifact_size_bytes": {
          "description": "Byte size of the exact artifact bytes written to storage.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "job_id": {
          "description": "Durable parse-job identifier owned by `server-2`.",
          "type": "string"
        },
        "message_type": {
          "description": "Result message routing kind.",
          "$ref": "#/$defs/ParseResultKind"
        },
        "parser": {
          "description": "Parser binary metadata.",
          "$ref": "#/$defs/ParserInfo"
        },
        "parser_contract_version": {
          "description": "Parser artifact contract version used for the artifact.",
          "$ref": "#/$defs/ContractVersion"
        },
        "replay_id": {
          "description": "Replay identifier owned by `server-2`.",
          "type": "string"
        },
        "source_checksum": {
          "description": "Verified raw replay source checksum.",
          "$ref": "#/$defs/SourceChecksum"
        }
      },
      "required": [
        "message_type",
        "job_id",
        "replay_id",
        "parser_contract_version",
        "source_checksum",
        "artifact",
        "artifact_checksum",
        "artifact_size_bytes",
        "parser"
      ]
    },
    "ParseFailedMessage": {
      "description": "Failed parser-worker result message.",
      "type": "object",
      "properties": {
        "failure": {
          "description": "Structured parse or worker failure.",
          "$ref": "#/$defs/ParseFailure"
        },
        "job_id": {
          "description": "Durable parse-job identifier, when it could be read from the job.",
          "$ref": "#/$defs/FieldPresence"
        },
        "message_type": {
          "description": "Result message routing kind.",
          "$ref": "#/$defs/ParseResultKind"
        },
        "object_key": {
          "description": "S3-compatible raw replay object key, when it could be read from the job.",
          "$ref": "#/$defs/FieldPresence"
        },
        "parser": {
          "description": "Parser binary metadata.",
          "$ref": "#/$defs/ParserInfo"
        },
        "parser_contract_version": {
          "description": "Parser artifact contract version, when it could be read from the job.",
          "$ref": "#/$defs/FieldPresence2"
        },
        "replay_id": {
          "description": "Replay identifier, when it could be read from the job.",
          "$ref": "#/$defs/FieldPresence"
        },
        "source_checksum": {
          "description": "Expected raw replay source checksum, when it could be read from the job.",
          "$ref": "#/$defs/FieldPresence3"
        }
      },
      "required": [
        "message_type",
        "job_id",
        "replay_id",
        "object_key",
        "parser_contract_version",
        "source_checksum",
        "failure",
        "parser"
      ]
    },
    "ParseFailure": {
      "description": "Machine-readable parse failure payload.",
      "type": "object",
      "properties": {
        "checksum": {
          "description": "Source checksum state.",
          "$ref": "#/$defs/FieldPresence3"
        },
        "error_code": {
          "description": "Stable failure code.",
          "$ref": "#/$defs/ErrorCode"
        },
        "job_id": {
          "description": "Parse job identifier, when supplied by the adapter.",
          "$ref": "#/$defs/FieldPresence"
        },
        "message": {
          "description": "Human-readable failure message.",
          "type": "string"
        },
        "replay_id": {
          "description": "Replay identifier, when supplied by the caller or source.",
          "$ref": "#/$defs/FieldPresence"
        },
        "retryability": {
          "description": "Retryability classification.",
          "$ref": "#/$defs/Retryability"
        },
        "source_cause": {
          "description": "Original lower-level cause, when safe to expose.",
          "$ref": "#/$defs/FieldPresence"
        },
        "source_file": {
          "description": "Source file or object path.",
          "$ref": "#/$defs/FieldPresence"
        },
        "source_refs": {
          "description": "Source references associated with the failure.",
          "$ref": "#/$defs/SourceRefs"
        },
        "stage": {
          "description": "Parser stage where the failure occurred.",
          "$ref": "#/$defs/ParseStage"
        }
      },
      "required": [
        "job_id",
        "replay_id",
        "source_file",
        "checksum",
        "stage",
        "error_code",
        "message",
        "retryability",
        "source_cause",
        "source_refs"
      ]
    },
    "ParseResultKind": {
      "description": "Worker result routing kind.",
      "oneOf": [
        {
          "description": "Successful parse result with a durable artifact reference.",
          "type": "string",
          "const": "parse.completed"
        },
        {
          "description": "Failed parse result with structured failure data.",
          "type": "string",
          "const": "parse.failed"
        }
      ]
    },
    "ParseStage": {
      "description": "Parser stage where a structured failure occurred.",
      "oneOf": [
        {
          "description": "Input file or object access stage.",
          "type": "string",
          "const": "input"
        },
        {
          "description": "Source checksum validation stage.",
          "type": "string",
          "const": "checksum"
        },
        {
          "description": "JSON decoding stage.",
          "type": "string",
          "const": "json_decode"
        },
        {
          "description": "Contract or source schema validation stage.",
          "type": "string",
          "const": "schema"
        },
        {
          "description": "Replay normalization stage.",
          "type": "string",
          "const": "normalize"
        },
        {
          "description": "Aggregate derivation stage.",
          "type": "string",
          "const": "aggregate"
        },
        {
          "description": "Output writing or publishing stage.",
          "type": "string",
          "const": "output"
        },
        {
          "description": "Internal invariant or unexpected parser stage.",
          "type": "string",
          "const": "internal"
        }
      ]
    },
    "ParserBuildInfo": {
      "description": "Optional parser build metadata.",
      "type": "object",
      "properties": {
        "git_commit": {
          "description": "Git commit used to build the parser.",
          "type": [
            "string",
            "null"
          ]
        },
        "profile": {
          "description": "Cargo profile.",
          "type": [
            "string",
            "null"
          ]
        },
        "target": {
          "description": "Rust compilation target.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ParserInfo": {
      "description": "Parser binary metadata embedded in each artifact.",
      "type": "object",
      "properties": {
        "build": {
          "description": "Optional build metadata for non-deterministic adapter contexts.",
          "anyOf": [
            {
              "$ref": "#/$defs/ParserBuildInfo"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "description": "Parser binary name.",
          "type": "string"
        },
        "version": {
          "description": "Parser binary version.",
          "$ref": "#/$defs/SemVer"
        }
      },
      "required": [
        "name",
        "version"
      ]
    },
    "Retryability": {
      "description": "Retryability classification for a parse failure.",
      "oneOf": [
        {
          "description": "Retrying the same job may succeed.",
          "type": "string",
          "const": "retryable"
        },
        {
          "description": "Retrying the same job is not expected to succeed.",
          "type": "string",
          "const": "not_retryable"
        },
        {
          "description": "Retryability could not be determined.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "RuleId": {
      "description": "Stable parser rule identifier.",
      "type": "string"
    },
    "SemVer": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "SourceChecksum": {
      "description": "Source checksum with algorithm metadata.",
      "type": "object",
      "properties": {
        "algorithm": {
          "description": "Checksum algorithm.",
          "$ref": "#/$defs/ChecksumAlgorithm"
        },
        "value": {
          "description": "Checksum value.",
          "$ref": "#/$defs/ChecksumValue"
        }
      },
      "required": [
        "algorithm",
        "value"
      ]
    },
    "SourceRef": {
      "description": "Source coordinate for replay evidence used by normalized events and aggregates.",
      "type": "object",
      "properties": {
        "checksum": {
          "description": "Source checksum coordinate.",
          "anyOf": [
            {
              "$ref": "#/$defs/SourceChecksum"
            },
            {
              "type": "null"
            }
          ]
        },
        "entity_id": {
          "description": "Entity identifier coordinate.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "event_index": {
          "description": "Event index coordinate.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "frame": {
          "description": "Frame coordinate.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "json_path": {
          "description": "JSON path coordinate.",
          "type": [
            "string",
            "null"
          ]
        },
        "replay_id": {
          "description": "Replay identifier coordinate.",
          "type": [
            "string",
            "null"
          ]
        },
        "rule_id": {
          "description": "Rule identifier coordinate.",
          "anyOf": [
            {
              "$ref": "#/$defs/RuleId"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_file": {
          "description": "Source file coordinate.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "SourceRefs": {
      "description": "Non-empty source reference list.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/SourceRef"
      },
      "minItems": 1
    },
    "UnknownReason": {
      "description": "Reason for an unknown field state.",
      "oneOf": [
        {
          "description": "`SteamID` is absent from the source.",
          "type": "string",
          "const": "missing_steam_id"
        },
        {
          "description": "Winner is absent from the source.",
          "type": "string",
          "const": "missing_winner"
        },
        {
          "description": "Commander data is absent from the source.",
          "type": "string",
