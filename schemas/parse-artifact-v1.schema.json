{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ParseArtifact",
  "type": "object",
  "properties": {
    "aggregates": {
      "$ref": "#/$defs/AggregateSection"
    },
    "contract_version": {
      "$ref": "#/$defs/SemVer"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Diagnostic"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ObservedEntity"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NormalizedEvent"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "failure": {
      "anyOf": [
        {
          "$ref": "#/$defs/ParseFailure"
        },
        {
          "type": "null"
        }
      ]
    },
    "parser": {
      "$ref": "#/$defs/ParserInfo"
    },
    "produced_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "replay": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReplayMetadata"
        },
        {
          "type": "null"
        }
      ]
    },
    "source": {
      "$ref": "#/$defs/ReplaySource"
    },
    "status": {
      "$ref": "#/$defs/ParseStatus"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure": {
            "$ref": "#/$defs/ParseFailure"
          }
        },
        "required": [
          "failure"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "success",
              "partial",
              "skipped"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "failure": {
            "type": "null"
          }
        }
      }
    }
  ],
  "required": [
    "contract_version",
    "parser",
    "source",
    "status",
    "diagnostics",
    "entities",
    "events",
    "aggregates",
    "extensions"
  ],
  "$defs": {
    "AggregateContributionKind": {
      "type": "string",
      "enum": [
        "legacy_counter",
        "bounty_input",
        "vehicle_score_input",
        "relationship",
        "unknown"
      ]
    },
    "AggregateContributionRef": {
      "type": "object",
      "properties": {
        "contribution_id": {
          "type": "string"
        },
        "event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/$defs/AggregateContributionKind"
        },
        "rule_id": {
          "type": "string"
        },
        "source_refs": {
          "$ref": "#/$defs/SourceRefs"
        },
        "value": true
      },
      "required": [
        "contribution_id",
        "kind",
        "source_refs",
        "rule_id",
        "value"
      ]
    },
    "AggregateSection": {
      "type": "object",
      "properties": {
        "contributions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AggregateContributionRef"
          }
        },
        "projections": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "contributions",
        "projections"
      ]
    },
    "ChecksumAlgorithm": {
      "type": "string",
      "enum": [
        "sha256"
      ]
    },
    "ChecksumValue": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "Confidence": {
      "type": "number",
      "format": "float",
      "maximum": 1.0,
      "minimum": 0.0
    },
    "Diagnostic": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "expected_shape": {
          "type": [
            "string",
            "null"
          ]
        },
        "json_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "observed_shape": {
          "type": [
            "string",
            "null"
          ]
        },
        "parser_action": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/DiagnosticSeverity"
        },
        "source_refs": {
          "$ref": "#/$defs/SourceRefs"
        }
      },
      "required": [
        "code",
        "severity",
        "message",
        "parser_action",
        "source_refs"
      ]
    },
    "DiagnosticSeverity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error"
      ]
    },
    "EntityKind": {
      "type": "string",
      "enum": [
        "unit",
        "vehicle",
        "static_weapon",
        "unknown"
      ]
    },
    "EntitySide": {
      "type": "string",
      "enum": [
        "east",
        "west",
        "guer",
        "civ",
        "unknown"
      ]
    },
    "ErrorCode": {
      "type": "string",
      "pattern": "^(io|json|schema|unsupported|internal|checksum|output)\\.[a-z0-9_-]+(\\.[a-z0-9_-]+)*$"
    },
    "EventActorRef": {
      "type": "object",
      "properties": {
        "observed_name": {
          "$ref": "#/$defs/FieldPresence2"
        },
        "side": {
          "$ref": "#/$defs/FieldPresence8"
        },
        "source_entity_id": {
          "$ref": "#/$defs/FieldPresence9"
        }
      },
      "required": [
        "source_entity_id",
        "observed_name",
        "side"
      ]
    },
    "FieldPresence": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "source": {
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "present"
            },
            "value": {
              "$ref": "#/$defs/SourceChecksum"
            }
          },
          "required": [
            "state",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/NullReason"
            },
            "source": {
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "explicit_null"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/UnknownReason"
            },
            "source": {
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "unknown"
            }
          },
          "required": [
            "state",
            "reason"
          ]
        },
        {
          "type": "object",
          "properties": {
            "confidence": {
              "anyOf": [
                {
                  "$ref": "#/$defs/Confidence"
                },
                {
                  "type": "null"
                }
              ]
            },
            "reason": {
              "type": "string"
            },
            "rule_id": {
              "type": "string"
            },
            "source": {
              "anyOf": [
                {
                  "$ref": "#/$defs/SourceRef"
                },
                {
                  "type": "null"
                }
              ]
            },
            "state": {
              "type": "string",
              "const": "inferred"
            },
            "value": {
              "$ref": "#/$defs/SourceChecksum"
            }
          },
          "required": [
            "state",
            "value",
            "reason",
            "rule_id"
          ]
        },
        {
          "type": "object",
